{
  "name": "@booga/vlint",
  "version": "0.1.1",
  "description": "AST linter for vDsl prop surface — token scale validation, className/style bypass guards, ESLint plugin.",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "bin": {
    "vlint": "./dist/cli.js"
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit",
    "test": "vitest run --coverage",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@babel/parser": "^7.24.0",
    "@babel/traverse": "^7.24.0",
    "@babel/types": "^7.24.0",
    "commander": "^12.0.0",
    "picocolors": "^1.0.0",
    "zod": "^3.22.0"
  },
  "peerDependencies": {
    "@booga/vdsl": "^0.2.0",
    "eslint": "^8"
  },
  "peerDependenciesMeta": {
    "@booga/vdsl": { "optional": true },
    "eslint": { "optional": true }
  },
  "devDependencies": {
    "@types/babel__traverse": "^7.20.0",
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^3.0.0",
    "eslint": "^8.57.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^3.0.0"
  }
}
